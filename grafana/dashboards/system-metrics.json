{
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "panels": [
    {
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "content": "# System Metrics (Assignment 3)\n\n**CPU / RAM** — `process_*` from each microservice | **RPS** — HTTP histogram | **Errors** — SLI recording rules | **Uptime** — Prometheus `up`\n\nGenerate traffic at http://localhost:8088 so graphs move over time.",
        "mode": "markdown"
      },
      "title": "Overview",
      "type": "text"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 3 },
      "id": 101,
      "title": "Cluster overview (time series)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "CPU %",
            "drawStyle": "line",
            "fillOpacity": 25,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": true
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "100 * sum(rate(process_cpu_seconds_total{job=~\".*-service\"}[1m]))",
          "legendFormat": "Total CPU (all services)",
          "refId": "A"
        }
      ],
      "title": "CPU usage (aggregate)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "Memory",
            "drawStyle": "line",
            "fillOpacity": 25,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": true
          },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum(process_resident_memory_bytes{job=~\".*-service\"})",
          "legendFormat": "Total RSS (all services)",
          "refId": "A"
        }
      ],
      "title": "Memory usage (aggregate)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "req/s",
            "drawStyle": "line",
            "fillOpacity": 25,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": true
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_count[1m]))",
          "legendFormat": "HTTP RPS (total)",
          "refId": "A"
        }
      ],
      "title": "Request rate (RPS)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "Error %",
            "drawStyle": "line",
            "fillOpacity": 25,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": true,
            "thresholdsStyle": { "mode": "dashed" }
          },
          "max": 5,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sli:error_rate:percent",
          "legendFormat": "Error rate SLI",
          "refId": "A"
        },
        {
          "expr": "vector(1)",
          "legendFormat": "SLO 1%",
          "refId": "B"
        }
      ],
      "title": "Error rate (%)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "id": 102,
      "title": "Per microservice",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "CPU %",
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": true
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "100 * sum by (job) (rate(process_cpu_seconds_total{job=~\".*-service\"}[1m]))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "CPU by service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "Memory",
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": true
          },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "id": 8,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=~\".*-service\"}",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "Memory by service (RSS)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "req/s",
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": true
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 29 },
      "id": 9,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (service) (rate(http_request_duration_seconds_count[1m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "title": "Request rate by service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "Uptime %",
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "max": 100,
          "min": 0,
          "unit": "percent"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 29 },
      "id": 10,
      "options": {
        "legend": { "calcs": ["min", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "up{job=~\".*-service\"} * 100",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "Uptime per microservice",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["monitoring", "cpu", "memory", "rps", "uptime"],
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m"],
    "time_options": ["5m", "15m", "30m", "1h"]
  },
  "timezone": "browser",
  "title": "System Metrics — CPU / RAM / RPS / Errors / Uptime",
  "uid": "system-metrics",
  "version": 2
}
